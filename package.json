{
  "name": "autolog",
  "version": "1.0.0",
  "description": "AutoLog - Car maintenance tracker & reminder app",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npx vite --host",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd client && npm install && npx vite build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.13.0",
    "cors": "^2.8.5",
    "concurrently": "^8.2.2"
  }
}
